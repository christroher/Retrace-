{
  "manifest_version": 3,
  "name": "Retrace 回溯足迹",
  "short_name": "Retrace",
  "version": "0.1.0",
  "description": "在右侧侧边栏中快速浏览、搜索、找回浏览历史",
  "permissions": [
    "history",
    "sidePanel",
    "storage",
    "favicon"
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+H",
        "mac": "Command+Shift+H"
      },
      "description": "打开 Retrace 侧边栏"
    },
    "toggle-sidebar": {
      "suggested_key": {
        "default": "Ctrl+Shift+R",
        "mac": "Command+Shift+R"
      },
      "description": "切换 Retrace 侧边栏显示/隐藏"
    }
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Retrace 回溯足迹"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
